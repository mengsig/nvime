    "plan_resilient_outbox": {
        "difficulty": "extremely_difficult",
        "title": "Plan a resilient outbox with idempotency keys + dead-letter queue",
        "intent": (
            "Plan the implementation of a resilient outbox spread across `outbox.py` "
            "(public API + retry policy), `storage.py` (in-memory store with "
            "deterministic iteration), and a regression test file.\n"
            "\n"
            "API contract (DO NOT change these names or signatures):\n"
            "  - `InMemoryStore` keeps its current public methods `add(message)` "
            "    and `all()`. `add` appends; `all` returns the messages. New helpers "
            "    may be added but `add` and `all` MUST remain.\n"
            "  - `Outbox(store, *, max_attempts=3, base_delay=1.0, rng=None)`. "
            "    `rng` is a no-arg callable returning a float in [0.0, 1.0]; default "
            "    to `random.random` when None.\n"
            "  - `Outbox.enqueue(message)` takes a single dict argument. The dict "
            "    carries `payload` and `idempotency_key` as keys (NOT a separate "
            "    keyword argument). Returns the idempotency key actually stored. "
            "    Enqueueing a message whose `idempotency_key` already exists is a "
            "    no-op and returns the existing key.\n"
            "  - `Outbox.process_once(now, send_fn)` calls `send_fn(message)` for "
            "    every pending message whose `not_before <= now`, in FIFO order; on "
            "    success the message is removed from the store; on raised exception "
            "    the message is rescheduled with exponential backoff "
            "    `delay = base_delay * (2 ** attempt)` plus jitter strictly bounded "
            "    by `0 <= jitter <= 0.25 * delay` (computed from the injected `rng`); "
            "    after `max_attempts` failures the message moves to a dead-letter "
            "    list accessible via `Outbox.dead_letters()` returning a list of "
            "    the original message dicts.\n"
            "  - `store.all()` must NOT alias internal storage: callers that take "
            "    `list(store.all())` and then enqueue more messages must NOT see "
            "    the new messages in their captured snapshot.\n"
            "Plan must touch at least the three files above plus add focused tests."
        ),
        "files": {
            "outbox.py": """
                # Skeleton — production implementation will be added by the plan steps.

                class Outbox:
                    def __init__(self, store, *, max_attempts=3, base_delay=1.0, rng=None):
                        self._store = store
                        self._max_attempts = max_attempts
                        self._base_delay = base_delay
                        self._rng = rng

                    def enqueue(self, message):
                        raise NotImplementedError

                    def process_once(self, now, send_fn):
                        raise NotImplementedError

                    def dead_letters(self):
                        raise NotImplementedError
            """,
            "storage.py": """
                # In-memory store skeleton.

                class InMemoryStore:
                    def __init__(self):
                        self._messages = []

                    def add(self, message):
                        self._messages.append(message)

                    def all(self):
                        return self._messages
            """,
            "test_outbox.py": """
                import unittest

                from outbox import Outbox
                from storage import InMemoryStore


                class OutboxBaselineTests(unittest.TestCase):
                    def test_skeleton_is_unimplemented(self):
                        outbox = Outbox(InMemoryStore())
                        with self.assertRaises(NotImplementedError):
                            outbox.enqueue({"id": 1})


                if __name__ == "__main__":
                    unittest.main()
            """,
            "README.md": """
                # Outbox

                Buffer outgoing messages with retry semantics. The current skeleton
                only declares the API surface; the implementation lands through the
                accepted plan.
            """,
        },
        "hidden_files": {
            "test_hidden_outbox.py": """
                import unittest

                from outbox import Outbox
                from storage import InMemoryStore


                class HiddenOutboxTests(unittest.TestCase):
                    def test_idempotent_enqueue_returns_same_key(self):
                        outbox = Outbox(InMemoryStore(), rng=lambda: 0.0)
                        key1 = outbox.enqueue({"payload": "x", "idempotency_key": "k1"})
                        key2 = outbox.enqueue({"payload": "x", "idempotency_key": "k1"})
                        self.assertEqual(key1, key2)

                    def test_successful_send_is_removed(self):
                        outbox = Outbox(InMemoryStore(), rng=lambda: 0.0)
                        outbox.enqueue({"payload": "x", "idempotency_key": "k1"})
                        sent = []
                        outbox.process_once(now=0.0, send_fn=lambda m: sent.append(m["payload"]))
                        self.assertEqual(sent, ["x"])
                        outbox.process_once(now=10.0, send_fn=lambda m: sent.append(m["payload"]))
                        self.assertEqual(sent, ["x"])

                    def test_failure_reschedules_with_backoff(self):
                        outbox = Outbox(InMemoryStore(), max_attempts=4, base_delay=2.0, rng=lambda: 0.5)
                        outbox.enqueue({"payload": "x", "idempotency_key": "k1"})

                        def boom(_):
                            raise RuntimeError("send broke")

                        outbox.process_once(now=0.0, send_fn=boom)
                        # base_delay 2.0 * 2**0 = 2.0; jitter <= 25% of 2.0 = 0.5; rng=0.5 -> +0.25
                        # so not_before is in [2.0, 2.5]; trying at 1.0 should be a no-op.
                        attempts = []
                        outbox.process_once(now=1.0, send_fn=lambda m: attempts.append(m))
                        self.assertEqual(attempts, [])

                    def test_dead_letter_after_max_attempts(self):
                        outbox = Outbox(InMemoryStore(), max_attempts=2, base_delay=0.0, rng=lambda: 0.0)
                        outbox.enqueue({"payload": "x", "idempotency_key": "k1"})

                        def boom(_):
                            raise RuntimeError("nope")

                        outbox.process_once(now=0.0, send_fn=boom)
                        outbox.process_once(now=1.0, send_fn=boom)
                        dead = outbox.dead_letters()
                        self.assertEqual(len(dead), 1)
                        self.assertEqual(dead[0]["payload"], "x")

                    def test_pending_iteration_does_not_alias_internal_state(self):
                        store = InMemoryStore()
                        outbox = Outbox(store, rng=lambda: 0.0)
                        outbox.enqueue({"payload": "a", "idempotency_key": "ka"})
                        snapshot = list(store.all())
                        outbox.enqueue({"payload": "b", "idempotency_key": "kb"})
                        self.assertEqual(len(snapshot), 1)


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
    },
}


def clean(text: str) -> str:
    return textwrap.dedent(text).lstrip("\n")


def write_project_files(root: Path, files: dict[str, str]) -> None:
    for rel, body in files.items():
        out_lines = [
            line
            for line in clean(body).splitlines()
            if "NVIME_SELECT_START" not in line and "NVIME_SELECT_END" not in line
        ]
        path = root / rel
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text("\n".join(out_lines) + "\n", encoding="utf-8")


def init_repo(root: Path) -> None:
    run(["git", "init", "-q"], root)
    run(["git", "config", "user.email", "nvime@example.invalid"], root)
    run(["git", "config", "user.name", "nvime exercise"], root)
    run(["git", "add", "."], root)
    run(["git", "commit", "-qm", "initial"], root)


def run(cmd: list[str] | str, cwd: Path, *, text: str | None = None, timeout: int = 600) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        cmd,
        input=text,
        cwd=cwd,
        text=True,
        shell=isinstance(cmd, str),
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        timeout=timeout,
    )


def prepare_exercise(name: str, root: Path) -> dict[str, Any]:
    exercise = EXERCISES[name]
    selection: dict[str, Any] | None = None
    for rel, body in exercise["files"].items():
        out_lines: list[str] = []
        selecting = False
        line1 = None
        line2 = None
        for raw in clean(body).splitlines():
            if "NVIME_SELECT_START" in raw:
                selecting = True
                continue
            if "NVIME_SELECT_END" in raw:
                selecting = False
                continue
            out_lines.append(raw)
            if selecting:
                line1 = line1 or len(out_lines)
                line2 = len(out_lines)
        path = root / rel
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text("\n".join(out_lines) + "\n", encoding="utf-8")
        if rel == exercise["target"]:
            if line1 is None or line2 is None:
                raise RuntimeError(f"{name}: target has no selection markers")
            selection = {"path": rel, "line1": line1, "line2": line2}
    if selection is None:
        raise RuntimeError(f"{name}: no target selection")
    init_repo(root)
    return selection


def prepare_general_exercise(name: str, root: Path) -> None:
    write_project_files(root, GENERAL_EXERCISES[name]["files"])
    init_repo(root)


def prepare_plan_exercise(name: str, root: Path) -> None:
    write_project_files(root, PLAN_EXERCISES[name]["files"])
    init_repo(root)


def write_hidden_files(root: Path, exercise: dict[str, Any]) -> list[str]:
    hidden = exercise.get("hidden_files") or {}
    write_project_files(root, hidden)
    return sorted(hidden)


def build_nvime_prompt(workspace: Path, exercise: dict[str, Any], selection: dict[str, Any], intent: str | None = None) -> str:
    prompt_path = workspace / ".prompt.txt"
    lua_path = workspace / ".build_prompt.lua"
    lua_path.write_text(
        textwrap.dedent(
            """
            vim.cmd("set rtp^=" .. vim.env.NVIME_PLUGIN_ROOT)
            local target = vim.env.NVIME_EXERCISE_TARGET
            vim.cmd("edit " .. vim.fn.fnameescape(target))
            local selection = {
              bufnr = vim.api.nvim_get_current_buf(),
              path = vim.env.NVIME_EXERCISE_REL,
              line1 = tonumber(vim.env.NVIME_EXERCISE_LINE1),
              line2 = tonumber(vim.env.NVIME_EXERCISE_LINE2),
              source = "agent exercise",
            }
            local prompt = require("nvime.edit")._build_prompt(selection, vim.env.NVIME_EXERCISE_INTENT)
            vim.fn.writefile(vim.split(prompt, "\\n", { plain = true }), vim.env.NVIME_EXERCISE_PROMPT)
            vim.cmd("qa!")
            """
        ).lstrip("\n"),
        encoding="utf-8",
    )
    env = os.environ.copy()
    env.update(
        {
            "NVIME_PLUGIN_ROOT": str(REPO_ROOT),
            "NVIME_EXERCISE_TARGET": str(workspace / exercise["target"]),
            "NVIME_EXERCISE_REL": exercise["target"],
            "NVIME_EXERCISE_LINE1": str(selection["line1"]),
            "NVIME_EXERCISE_LINE2": str(selection["line2"]),
            "NVIME_EXERCISE_INTENT": intent or exercise["intent"],
            "NVIME_EXERCISE_PROMPT": str(prompt_path),
        }
    )
    proc = subprocess.run(
        ["nvim", "--headless", "-u", "NONE", "-l", str(lua_path)],
        cwd=workspace,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=env,
        timeout=60,
    )
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr or proc.stdout)
    return prompt_path.read_text(encoding="utf-8")


def build_lua_prompt(workspace: Path, lua_source: str, extra_env: dict[str, str] | None = None) -> str:
    prompt_path = workspace / ".prompt.txt"
    lua_path = workspace / ".build_prompt.lua"
    lua_path.write_text(textwrap.dedent(lua_source).lstrip("\n"), encoding="utf-8")
    env = os.environ.copy()
    env.update(
        {
            "NVIME_PLUGIN_ROOT": str(REPO_ROOT),
            "NVIME_EXERCISE_PROMPT": str(prompt_path),
        }
    )
    if extra_env:
        env.update(extra_env)
    proc = subprocess.run(
        ["nvim", "--headless", "-u", "NONE", "-l", str(lua_path)],
        cwd=workspace,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=env,
        timeout=60,
    )
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr or proc.stdout)
    return prompt_path.read_text(encoding="utf-8")


def build_general_prompt(workspace: Path, intent: str) -> str:
    return build_lua_prompt(
        workspace,
        """
        vim.cmd("set rtp^=" .. vim.env.NVIME_PLUGIN_ROOT)
        require("nvime").setup({
          sessions = { enabled = false },
          review = { allow_shell = true, allow_web = false, allow_markdown_writes = false },
        })
        local prompt = require("nvime.chat")._build_conversation_prompt(vim.env.NVIME_GENERAL_INTENT, {
          session = { history = {} },
        })
        vim.fn.writefile(vim.split(prompt, "\\n", { plain = true }), vim.env.NVIME_EXERCISE_PROMPT)
        vim.cmd("qa!")
        """,
        {"NVIME_GENERAL_INTENT": intent},
    )


def build_plan_prompt(workspace: Path, intent: str) -> str:
    return build_lua_prompt(
        workspace,
        """
        vim.cmd("set rtp^=" .. vim.env.NVIME_PLUGIN_ROOT)
        require("nvime").setup({ sessions = { enabled = false } })
        local prompt = require("nvime.plan")._build_author_prompt(vim.env.NVIME_PLAN_INTENT)
        vim.fn.writefile(vim.split(prompt, "\\n", { plain = true }), vim.env.NVIME_EXERCISE_PROMPT)
        vim.cmd("qa!")
        """,
        {"NVIME_PLAN_INTENT": intent},
    )


def default_prompt(exercise: dict[str, Any]) -> str:
    return textwrap.dedent(
        f"""
        You are in a temporary coding exercise repository.

        Implement the requested change directly in the source file. Keep the
        change minimal, do not edit tests, and do not touch unrelated files.
        Run `{runner_for(exercise)}` before the final answer.

        Difficulty: {exercise["difficulty"]}
        Target file: {exercise["target"]}
        Task: {exercise["intent"]}
        """
    ).strip()


def prompt_checks(prompt: str, mode: str, baseline_exit: int, runner: str = RUNNER) -> dict[str, bool]:
    checks = {"baseline_tests_pass": baseline_exit == 0} if mode == "plan" else {"baseline_fails": baseline_exit != 0}
    if mode == "nvime":
        checks.update(
            {
                "has_precomputed_context": "Precomputed nvime project context" in prompt,
                "has_machine_response_contract": "Return exactly one machine-readable response block" in prompt,
            }
        )
        # Python-only prompt assertions: nvime's precomputed context detects the
        # unittest runner + a related test_*.py excerpt. A non-Python fixture
        # uses a different runner and has no such excerpt — that is correct, not
        # a failure — so only assert these for the default Python harness. The
        # framework itself stays language-agnostic.
        if runner == RUNNER:
            checks.update(
                {
                    "has_unittest_runner": "Detected test runner: python -m unittest -q" in prompt,
                    "has_related_test_excerpt": "Related test file:" in prompt,
                }
            )
    elif mode == "general":
        checks.update(
            {
                "is_chat_mode": "NVIME CHAT MODE." in prompt,
                "guards_source_edits": "Never edit non-Markdown files from this lane" in prompt,
                "allows_shell_inspection": "You may run shell commands" in prompt,
                "no_progress_narration": "Do not narrate tool use or progress" in prompt,
            }
        )
    elif mode == "plan":
        checks.update(
            {
                "is_plan_author_mode": "NVIME PLAN AUTHOR MODE." in prompt,
                "no_progress_narration": "Do not narrate tool use, investigation progress, or status updates" in prompt,
                "only_plan_writes": "ONLY for paths under `.nvime/plans/<plan-id>/`" in prompt,
                "ordered_steps": "Decompose into ORDERED steps" in prompt,
                "range_anchor": "range_anchor" in prompt,
                "test_requirements": "Every step that changes runtime behavior MUST have" in prompt,
                "minimum_runtime_steps": "For runtime behavior changes, produce at least 3 steps" in prompt,
                "step_coherence_rule": "Step coherence (tests vs implementation)" in prompt,
            }
        )
    return checks


def parse_claude(stdout: str) -> str:
    chunks: list[str] = []
    seen: set[str] = set()

    def append_once(text: str) -> None:
        key = text.strip()
        if text and key and key not in seen:
            seen.add(key)
            chunks.append(text)

    for line in stdout.splitlines():
        try:
            item = json.loads(line)
        except json.JSONDecodeError:
            continue
        if item.get("type") == "assistant":
            message = item.get("message") or {}
            for block in message.get("content") or []:
                if isinstance(block, dict) and block.get("type") == "text":
                    append_once(block.get("text") or "")
        elif item.get("type") == "result" and item.get("result"):
            append_once(str(item["result"]))
    return "\n".join(chunks).strip()


def parse_codex(stdout: str) -> str:
    chunks: list[str] = []
    for line in stdout.splitlines():
        try:
            item = json.loads(line)
        except json.JSONDecodeError:
            continue
        payload = item.get("item") if item.get("type") == "item.completed" else None
        if isinstance(payload, dict) and payload.get("type") == "agent_message":
            chunks.append(payload.get("text") or "")
    return "\n".join(chunks).strip()


def write_mcp_config(workspace: Path) -> Path:
    """Materialize a Claude mcp-config that attaches nvime's OWN MCP server,
    scoped (via NVIME_REPO_ROOT) to the fixture workspace.

    This is what makes nvime's low-context navigation tools (nvime.find_symbol,
    tree_sitter_symbols, git_*, verify_file, ...) reachable inside a run, so we
    can A/B whether exposing them improves agent performance. The file is an
    untracked dotfile, so it never affects `scope_ok` (git diff --name-only).
    """
    nvim_bin = shutil.which("nvim") or "nvim"
    config = {
        "mcpServers": {
            "nvime": {
                "type": "stdio",
                "command": nvim_bin,
                "args": [
                    "--headless",
                    "--clean",
                    "--cmd",
                    f"set rtp+={REPO_ROOT}",
                    "--cmd",
                    "lua require('nvime.mcp_server').run()",
                ],
                "env": {"NVIME_REPO_ROOT": str(workspace)},
            }
        }
    }
    path = workspace / ".mcp-config.json"
    path.write_text(json.dumps(config), encoding="utf-8")
    return path


def call_provider(
    provider: str, mode: str, prompt: str, workspace: Path, timeout: int, with_mcp: bool = False
) -> tuple[subprocess.CompletedProcess[str], str]:
    if provider == "codex":
        sandbox = "workspace-write" if mode in {"default", "plan"} else "read-only"
        cmd = [
            "codex",
            "exec",
            "--json",
            "--ignore-user-config",
            "--ignore-rules",
            "--skip-git-repo-check",
            "--color",
            "never",
            "-s",
            sandbox,
            "-C",
            str(workspace),
            "-",
        ]
        proc = run(cmd, workspace, text=prompt, timeout=timeout)
        return proc, parse_codex(proc.stdout)

    if provider == "claude":
        tools = "Read,Grep,Glob,LS,Bash"
        allowed = tools
        disallowed = "Edit,Write,MultiEdit,NotebookEdit"
        if mode in {"default", "plan"}:
            tools = "Read,Grep,Glob,LS,Bash,Edit,Write,MultiEdit"
            allowed = tools
            disallowed = "NotebookEdit"
        # A/B lever: when --with-mcp is set, attach nvime's MCP server and grant
        # its tools. Built-in tools are kept identical, so the ONLY difference
        # between a with/without run is whether nvime's low-context navigation
        # helpers are reachable — a clean measurement of their effect.
        mcp_flags: list[str] = []
        if with_mcp:
            cfg_path = write_mcp_config(workspace)
            tools = tools + ",mcp__nvime"
            allowed = allowed + ",mcp__nvime"
            mcp_flags = ["--mcp-config", str(cfg_path), "--strict-mcp-config"]
        cmd = [
            "claude",
            "-p",
            "--output-format",
            "stream-json",
            "--verbose",
            "--permission-mode",
            "dontAsk",
            "--no-session-persistence",
            *mcp_flags,
            "--tools",
            tools,
            "--allowedTools",
            allowed,
            "--disallowedTools",
            disallowed,
        ]
        if os.environ.get("NVIME_AGENT_EXERCISE_CLAUDE_MODEL"):
            cmd.extend(["--model", os.environ["NVIME_AGENT_EXERCISE_CLAUDE_MODEL"]])
        if os.environ.get("NVIME_AGENT_EXERCISE_CLAUDE_BUDGET"):
            cmd.extend(["--max-budget-usd", os.environ["NVIME_AGENT_EXERCISE_CLAUDE_BUDGET"]])
        cmd.append(prompt)
        proc = run(cmd, workspace, timeout=timeout)
        return proc, parse_claude(proc.stdout)

    raise ValueError(provider)


def extract_fenced_after(marker: str, text: str, lang: str | None = None) -> str | None:
    language = re.escape(lang or "")
    pattern = marker + r"\s*```" + language + r"\s*\n(.*?)\n```"
    match = re.search(pattern, text, re.DOTALL)
    if match:
        return match.group(1)
    return None


def apply_nvime_response(workspace: Path, exercise: dict[str, Any], selection: dict[str, Any], response: str) -> str:
    replacement = extract_fenced_after("NVIME_REPLACEMENT", response)
    if replacement is not None:
        target = workspace / exercise["target"]
        lines = target.read_text(encoding="utf-8").splitlines()
        new_lines = replacement.splitlines()
        start = selection["line1"] - 1
        stop = selection["line2"]
        target.write_text("\n".join(lines[:start] + new_lines + lines[stop:]) + "\n", encoding="utf-8")
        selection["line2"] = selection["line1"] + max(len(new_lines), 1) - 1
        return "replacement"

    diff_text = extract_fenced_after("NVIME_DIFF", response, "diff")
    if diff_text is not None:
        if not diff_text.endswith("\n"):
            diff_text += "\n"
        proc = run(["git", "apply", "--unidiff-zero", "--recount", "-"], workspace, text=diff_text, timeout=30)
        if proc.returncode != 0:
            raise RuntimeError("git apply failed:\n" + proc.stderr + "\n" + diff_text)
        return "diff"

    if "NVIME_NO_CHANGE" in response:
        return "no_change"
    return "unparsed"


def changed_files(workspace: Path) -> list[str]:
    proc = run(["git", "diff", "--name-only"], workspace, timeout=30)
    return sorted(line for line in proc.stdout.splitlines() if line.strip())


def status_paths(workspace: Path) -> list[str]:
    proc = run(["git", "status", "--porcelain", "--untracked-files=all"], workspace, timeout=30)
    paths: list[str] = []
    for line in proc.stdout.splitlines():
        if not line.strip():
            continue
        paths.append(line[3:].strip())
    return sorted(paths)


def failure_tail(*parts: str, limit: int = 4000) -> str:
    text = "\n".join(part for part in parts if part)
    return text[-limit:]


def feedback_intent(original: str, runner: str, previous: dict[str, Any]) -> str:
    bits = [
        original,
        "",
        "Previous nvime patch attempt failed validation.",
        "Produce the smallest corrected patch for the same selected range.",
        "If the previous unified diff did not apply cleanly, prefer NVIME_REPLACEMENT for the full selected range.",
        "Do not repeat the same candidate unless you can explain why the failure output is unrelated.",
        "Test command: `" + runner + "`",
        "",
        "Failure details:",
        "----",
        failure_tail(
            previous.get("apply_error") or "",
            previous.get("test_stdout") or "",
            previous.get("test_stderr") or "",
            previous.get("hidden_stdout") or "",
            previous.get("hidden_stderr") or "",
        ),
        "----",
    ]
    return "\n".join(bits)


def validate_general_answer(exercise: dict[str, Any], answer: str) -> dict[str, bool]:
    lower = answer.lower()
    return {f"mentions_{needle.lower().replace(' ', '_')}": needle.lower() in lower for needle in exercise["must_contain"]}


def non_harness_status_paths(workspace: Path) -> list[str]:
    ignored = {".prompt.txt", ".build_prompt.lua"}
    return [
        path
        for path in status_paths(workspace)
        if path not in ignored
        and "__pycache__/" not in path
        and not path.endswith(".pyc")
        and not path.startswith(".pytest_cache/")
    ]


def validate_plan_output(workspace: Path, final_text: str) -> tuple[dict[str, bool], dict[str, Any]]:
    plan_jsons = sorted((workspace / ".nvime" / "plans").glob("*/plan.json"))
    details: dict[str, Any] = {
        "plan_files": [str(path.relative_to(workspace)) for path in plan_jsons],
    }
    checks: dict[str, bool] = {
        "emits_marker": "NVIME_PLAN" in final_text,
        "marker_is_first_output": final_text.lstrip().startswith("NVIME_PLAN"),
        "writes_one_plan_json": len(plan_jsons) == 1,
    }
    if len(plan_jsons) != 1:
        return checks, details

    plan_json = plan_jsons[0]
    plan_md = plan_json.with_name("plan.md")
    checks["writes_plan_md"] = plan_md.exists()
    try:
        plan = json.loads(plan_json.read_text(encoding="utf-8"))
    except Exception as exc:  # noqa: BLE001 - surfaced in JSON result
        details["json_error"] = str(exc)
        checks["valid_json"] = False
        return checks, details

    details["plan_id"] = plan.get("id")
    details["title"] = plan.get("title")
    details["step_count"] = len(plan.get("steps") or []) if isinstance(plan.get("steps"), list) else None
    checks.update(
        {
            "valid_json": True,
            "schema_version": plan.get("version") == 1,
            "id_matches_directory": plan.get("id") == plan_json.parent.name,
            "has_title_and_why": bool(plan.get("title")) and bool(plan.get("why")),
            "has_acceptance": isinstance(plan.get("acceptance"), list) and len(plan.get("acceptance")) >= 2,
            "has_reasonable_step_count": isinstance(plan.get("steps"), list) and 3 <= len(plan.get("steps")) <= 12,
        }
    )

    steps = plan.get("steps") if isinstance(plan.get("steps"), list) else []
    step_ids = [step.get("id") for step in steps if isinstance(step, dict)]
    checks["step_ids_unique"] = len(step_ids) == len(set(step_ids)) and len(step_ids) == len(steps)
    checks["all_steps_have_core_fields"] = all(
        isinstance(step, dict)
        and step.get("intent")
        and step.get("file")
        and step.get("range") is not None
        and isinstance(step.get("depends_on"), list)
        and step.get("status") == "pending"
        for step in steps
    )
    checks["line_ranges_have_anchors"] = all(
        not isinstance(step.get("range"), dict) or bool(step.get("range_anchor"))
        for step in steps
        if isinstance(step, dict)
    )
    checks["existing_ranges_point_to_files"] = all(
        step.get("range") == "new" or (workspace / str(step.get("file"))).exists()
        for step in steps
        if isinstance(step, dict)
    )
    checks["has_test_step_or_runner"] = any(
        (
            isinstance(step, dict)
            and (
                "test" in str(step.get("file", "")).lower()
                or any("test" in str(cmd).lower() or "unittest" in str(cmd).lower() for cmd in step.get("tests") or [])
            )
        )
        for step in steps
    )
    touched = non_harness_status_paths(workspace)
    details["status_paths"] = touched
    checks["only_plan_files_changed"] = all(path.startswith(".nvime/plans/") for path in touched)
    return checks, details


def load_single_plan(workspace: Path) -> dict[str, Any] | None:
    plan_jsons = sorted((workspace / ".nvime" / "plans").glob("*/plan.json"))
    if len(plan_jsons) != 1:
        return None
    try:
        return json.loads(plan_jsons[0].read_text(encoding="utf-8"))
    except Exception:
        return None


def plan_repair_prompt(original_prompt: str, validation: dict[str, Any]) -> str:
    return "\n".join(
        [
            original_prompt,
            "",
            "The previous plan failed nvime validation.",
            "Repair the plan in place under `.nvime/plans/<plan-id>/` and emit only the final NVIME_PLAN marker.",
            "Do not modify source files.",
            "Validation result:",
            "```json",
            json.dumps(validation, indent=2, sort_keys=True),
            "```",
        ]
    )


def step_execution_intent(plan: dict[str, Any], step: dict[str, Any]) -> str:
    lines = [
        "Execute this nvime plan step only.",
        "Do not implement later steps. Do not edit files outside this step's file/range.",
        "",
        f"Plan: {plan.get('id')} - {plan.get('title')}",
        f"Step {step.get('id')}: {step.get('intent')}",
    ]
    if step.get("notes"):
        lines.extend(["", "Step notes:", str(step["notes"])])
    if step.get("tests"):
        lines.extend(["", "Step tests:", *[f"- {cmd}" for cmd in step.get("tests") or []]])

    deps = step.get("depends_on") or []
    if deps:
        steps_by_id = {
            str(item.get("id")): item
            for item in (plan.get("steps") or [])
            if isinstance(item, dict) and item.get("id") is not None
        }
        seen: set[str] = set()
        ordered: list[dict[str, Any]] = []

        def collect(dep_id: Any) -> None:
            key = str(dep_id)
            if key in seen:
                return
            seen.add(key)
            dep = steps_by_id.get(key)
            if not dep:
                return
            for nested in dep.get("depends_on") or []:
                collect(nested)
            ordered.append(dep)

        for dep_id in deps:
            collect(dep_id)
        if ordered:
            lines.extend(
                [
                    "",
                    "Dependency-step intents (the contract this step must agree with — do not invent new signatures or bounds):",
                ]
            )
            for dep in ordered:
                lines.append(f"  [step {dep.get('id')}] {dep.get('intent') or '(no intent)'}")
                if dep.get("notes"):
                    lines.append(f"    notes: {dep.get('notes')}")
    return "\n".join(lines)


def locate_step_range(workspace: Path, step: dict[str, Any]) -> tuple[int, int]:
    range_value = step.get("range")
    path = workspace / str(step.get("file"))
    if range_value == "new":
        path.parent.mkdir(parents=True, exist_ok=True)
        if not path.exists():
            path.write_text("\n", encoding="utf-8")
        return 1, max(1, len(path.read_text(encoding="utf-8").splitlines()))
    if not isinstance(range_value, dict):
        raise RuntimeError(f"unsupported plan step range: {range_value!r}")
    line1 = int(range_value.get("line1") or 1)
    line2 = int(range_value.get("line2") or line1)
    anchor = step.get("range_anchor")
    if not anchor:
        return line1, line2
    lines = path.read_text(encoding="utf-8").splitlines()
    anchor_lines = str(anchor).splitlines()
    if not anchor_lines:
        return line1, line2
    width = max(0, line2 - line1)
    for index in range(0, len(lines) - len(anchor_lines) + 1):
        if lines[index : index + len(anchor_lines)] == anchor_lines:
            return index + 1, index + 1 + width
    return line1, line2


def expected_plan_change_files(plan: dict[str, Any]) -> set[str]:
    out = {str(step.get("file")) for step in plan.get("steps") or [] if isinstance(step, dict) and step.get("file")}
    return out


def execute_plan_steps(
    workspace: Path,
    plan: dict[str, Any],
    provider: str,
    timeout: int,
    fix_attempts: int,
) -> list[dict[str, Any]]:
    steps = [step for step in plan.get("steps") or [] if isinstance(step, dict)]
    steps.sort(key=lambda step: int(step.get("id") or 0))
    results: list[dict[str, Any]] = []
    completed: set[int] = set()
    for step in steps:
        step_id = int(step.get("id") or 0)
        missing_deps = [dep for dep in step.get("depends_on") or [] if int(dep) not in completed]
        if missing_deps:
            results.append(
                {
                    "step": step_id,
                    "success": False,
                    "applied": "dependency_blocked",
                    "error": f"missing dependencies: {missing_deps}",
                }
            )
            break
        step_result: dict[str, Any] | None = None
        for attempt_no in range(fix_attempts + 1):
            line1, line2 = locate_step_range(workspace, step)
            target = str(step["file"])
            selection = {"path": target, "line1": line1, "line2": line2}
            prompt = build_nvime_prompt(
                workspace,
                {"target": target, "intent": str(step.get("intent") or "")},
                selection,
                step_execution_intent(plan, step),
            )
            proc, final_text = call_provider(provider, "nvime", prompt, workspace, timeout)
            apply_error = None
            try:
                applied = apply_nvime_response(workspace, {"target": target}, selection, final_text)
            except Exception as exc:  # noqa: BLE001 - surfaced in JSON
                applied = "apply_failed"
                apply_error = str(exc)
            changed = changed_files(workspace)
            allowed = expected_plan_change_files(plan) | {f".nvime/plans/{plan.get('id')}/plan.json", f".nvime/plans/{plan.get('id')}/plan.md"}
            scope_ok = set(changed) <= allowed
            success = proc.returncode == 0 and applied not in {"unparsed", "no_change", "apply_failed"} and scope_ok
            step_result = {
                "step": step_id,
                "attempt": attempt_no + 1,
                "provider_exit": proc.returncode,
                "applied": applied,
                "apply_error": apply_error,
                "scope_ok": scope_ok,
                "changed_files": changed,
                "success": success,
                "final_text": final_text[-1600:],
            }
            if success or attempt_no >= fix_attempts:
                break
            step["intent"] = feedback_intent(str(step.get("intent") or ""), RUNNER, step_result)
        assert step_result is not None
        results.append(step_result)
        if not step_result["success"]:
            break
        completed.add(step_id)
    return results


def run_plan_execute_one(name: str, provider: str, live: bool, keep: bool, timeout: int, fix_attempts: int) -> dict[str, Any]:
    workspace = Path(tempfile.mkdtemp(prefix=f"nvime-plan-exec-{name}-"))
    exercise = PLAN_EXERCISES[name]
    try:
        prepare_plan_exercise(name, workspace)
        baseline = run(RUNNER, workspace, timeout=120)
        prompt = build_plan_prompt(workspace, exercise["intent"])
        checks = prompt_checks(prompt, "plan", baseline.returncode)
        prompt_ok = all(checks.values())
        if not live:
            return {
                "exercise": name,
                "difficulty": exercise["difficulty"],
                "mode": "plan-execute",
                "provider": provider,
                "workspace": str(workspace) if keep else None,
                "baseline_exit": baseline.returncode,
                "prompt_chars": len(prompt),
                "prompt_checks": checks,
                "prompt_ok": prompt_ok,
                "live": False,
            }
        if not prompt_ok:
            return {
                "exercise": name,
                "difficulty": exercise["difficulty"],
                "title": exercise["title"],
                "mode": "plan-execute",
                "provider": provider,
                "workspace": str(workspace) if keep else None,
                "baseline_exit": baseline.returncode,
                "prompt_checks": checks,
                "prompt_ok": False,
                "success": False,
                "error": "plan prompt self-check failed",
            }

        plan_attempts: list[dict[str, Any]] = []
        final_text = ""
        plan_checks: dict[str, bool] = {}
        plan_details: dict[str, Any] = {}
        for attempt_no in range(fix_attempts + 1):
            proc, final_text = call_provider(provider, "plan", prompt, workspace, timeout)
            plan_checks, plan_details = validate_plan_output(workspace, final_text)
            plan_attempt = {
                "attempt": attempt_no + 1,
                "provider_exit": proc.returncode,
                "success": proc.returncode == 0 and all(plan_checks.values()),
                "plan_checks": plan_checks,
                "plan_details": plan_details,
                "final_text": final_text[-1200:],
            }
            plan_attempts.append(plan_attempt)
            if plan_attempt["success"] or attempt_no >= fix_attempts:
                break
            prompt = plan_repair_prompt(prompt, plan_attempt)

        plan = load_single_plan(workspace)
        if not plan or not all(plan_checks.values()):
            return {
                "exercise": name,
                "difficulty": exercise["difficulty"],
                "title": exercise["title"],
                "mode": "plan-execute",
                "provider": provider,
                "workspace": str(workspace) if keep else None,
                "baseline_exit": baseline.returncode,
                "prompt_checks": checks,
                "prompt_ok": prompt_ok,
                "plan_attempts": plan_attempts,
                "success": False,
                "error": "plan validation failed",
            }

        step_results = execute_plan_steps(workspace, plan, provider, timeout, fix_attempts)
        visible = run(RUNNER, workspace, timeout=120)
        hidden_files = write_hidden_files(workspace, exercise)
        hidden = run(RUNNER, workspace, timeout=120) if hidden_files else None
        changed = changed_files(workspace)
        allowed = expected_plan_change_files(plan) | {f".nvime/plans/{plan.get('id')}/plan.json", f".nvime/plans/{plan.get('id')}/plan.md"}
        scope_ok = set(changed) <= allowed
        success = (
            all(item.get("success") for item in step_results)
            and visible.returncode == 0
            and (hidden is None or hidden.returncode == 0)
            and scope_ok
        )
        return {
            "exercise": name,
            "difficulty": exercise["difficulty"],
            "title": exercise["title"],
            "mode": "plan-execute",
            "provider": provider,
            "workspace": str(workspace) if keep else None,
            "baseline_exit": baseline.returncode,
            "prompt_checks": checks,
            "prompt_ok": prompt_ok,
            "plan_attempts": plan_attempts,
            "step_results": step_results,
            "visible_exit": visible.returncode,
            "visible_stdout": visible.stdout[-2000:],
            "visible_stderr": visible.stderr[-2000:],
            "hidden_files": hidden_files,
            "hidden_exit": hidden.returncode if hidden else None,
            "hidden_stdout": hidden.stdout[-2000:] if hidden else "",
            "hidden_stderr": hidden.stderr[-2000:] if hidden else "",
            "scope_ok": scope_ok,
            "changed_files": changed,
            "success": success,
        }
    finally:
        if not keep:
            shutil.rmtree(workspace, ignore_errors=True)


def run_general_one(name: str, provider: str, live: bool, keep: bool, timeout: int) -> dict[str, Any]:
    workspace = Path(tempfile.mkdtemp(prefix=f"nvime-general-{name}-"))
    exercise = GENERAL_EXERCISES[name]
    try:
        prepare_general_exercise(name, workspace)
        baseline = run(RUNNER, workspace, timeout=120)
        prompt = build_general_prompt(workspace, exercise["intent"])
        checks = prompt_checks(prompt, "general", baseline.returncode)
        prompt_ok = all(checks.values())
        if not live:
            return {
                "exercise": name,
                "difficulty": exercise["difficulty"],
                "mode": "general",
                "provider": provider,
                "workspace": str(workspace) if keep else None,
                "baseline_exit": baseline.returncode,
                "prompt_chars": len(prompt),
                "prompt_checks": checks,
                "prompt_ok": prompt_ok,
                "live": False,
            }
        if not prompt_ok:
            return {
                "exercise": name,
                "difficulty": exercise["difficulty"],
                "title": exercise["title"],
                "mode": "general",
                "provider": provider,
                "workspace": str(workspace) if keep else None,
                "baseline_exit": baseline.returncode,
                "prompt_chars": len(prompt),
                "prompt_checks": checks,
                "prompt_ok": False,
                "provider_exit": None,
                "answer_checks": {},
                "answer_ok": False,
                "scope_ok": True,
                "changed_files": [],
                "success": False,
                "final_text": "",
            }
        proc, final_text = call_provider(provider, "general", prompt, workspace, timeout)
        answer_checks = validate_general_answer(exercise, final_text)
        touched = non_harness_status_paths(workspace)
        scope_ok = touched == []
        answer_ok = all(answer_checks.values())
        return {
            "exercise": name,
            "difficulty": exercise["difficulty"],
            "title": exercise["title"],
            "mode": "general",
            "provider": provider,
            "workspace": str(workspace) if keep else None,
            "baseline_exit": baseline.returncode,
            "prompt_chars": len(prompt),
            "prompt_checks": checks,
            "prompt_ok": prompt_ok,
            "provider_exit": proc.returncode,
            "answer_checks": answer_checks,
            "answer_ok": answer_ok,
            "scope_ok": scope_ok,
            "changed_files": touched,
            "success": proc.returncode == 0 and answer_ok and scope_ok,
            "final_text": final_text[-2000:],
        }
    finally:
        if not keep:
            shutil.rmtree(workspace, ignore_errors=True)


def run_plan_one(name: str, provider: str, live: bool, keep: bool, timeout: int) -> dict[str, Any]:
    workspace = Path(tempfile.mkdtemp(prefix=f"nvime-plan-{name}-"))
    exercise = PLAN_EXERCISES[name]
    try:
        prepare_plan_exercise(name, workspace)
        baseline = run(RUNNER, workspace, timeout=120)
        prompt = build_plan_prompt(workspace, exercise["intent"])
        checks = prompt_checks(prompt, "plan", baseline.returncode)
        prompt_ok = all(checks.values())
        if not live:
            return {
                "exercise": name,
                "difficulty": exercise["difficulty"],
                "mode": "plan",
                "provider": provider,
                "workspace": str(workspace) if keep else None,
                "baseline_exit": baseline.returncode,
                "prompt_chars": len(prompt),
                "prompt_checks": checks,
                "prompt_ok": prompt_ok,
                "live": False,
            }
        if not prompt_ok:
            return {
                "exercise": name,
                "difficulty": exercise["difficulty"],
                "title": exercise["title"],
                "mode": "plan",
                "provider": provider,
                "workspace": str(workspace) if keep else None,
                "baseline_exit": baseline.returncode,
                "prompt_chars": len(prompt),
                "prompt_checks": checks,
                "prompt_ok": False,
                "provider_exit": None,
                "plan_checks": {},
                "plan_details": {},
                "success": False,
                "final_text": "",
            }
        proc, final_text = call_provider(provider, "plan", prompt, workspace, timeout)
        plan_checks, plan_details = validate_plan_output(workspace, final_text)
        plan_ok = all(plan_checks.values())
        return {
            "exercise": name,
            "difficulty": exercise["difficulty"],
            "title": exercise["title"],
            "mode": "plan",
            "provider": provider,
            "workspace": str(workspace) if keep else None,
            "baseline_exit": baseline.returncode,
            "prompt_chars": len(prompt),
            "prompt_checks": checks,
            "prompt_ok": prompt_ok,
            "provider_exit": proc.returncode,
            "plan_checks": plan_checks,
            "plan_details": plan_details,
            "success": proc.returncode == 0 and plan_ok,
            "final_text": final_text[-2000:],
        }
    finally:
        if not keep:
            shutil.rmtree(workspace, ignore_errors=True)


def run_one(
    name: str,
    provider: str,
    mode: str,
    live: bool,
    keep: bool,
    timeout: int,
    fix_attempts: int,
    with_mcp: bool = False,
) -> dict[str, Any]:
    workspace = Path(tempfile.mkdtemp(prefix=f"nvime-agent-{name}-"))
    exercise = EXERCISES[name]
    runner = runner_for(exercise)
    try:
      if not runner_available(runner):
          return {
              "exercise": name,
              "difficulty": exercise["difficulty"],
              "title": exercise.get("title", name),
              "mode": mode,
              "provider": provider,
              "skipped": True,
              "skip_reason": f"runner not available on PATH: {runner!r}",
              "runner": runner,
              "success": None,
              "live": live,
          }
      selection = prepare_exercise(name, workspace)
      baseline = run(runner, workspace, timeout=120)
      prompt = build_nvime_prompt(workspace, exercise, selection) if mode == "nvime" else default_prompt(exercise)
      checks = prompt_checks(prompt, mode, baseline.returncode, runner)
      prompt_ok = all(checks.values())
      if not live:
          return {
              "exercise": name,
              "difficulty": exercise["difficulty"],
              "mode": mode,
              "provider": provider,
              "workspace": str(workspace) if keep else None,
              "baseline_exit": baseline.returncode,
              "prompt_chars": len(prompt),
              "prompt_checks": checks,
              "prompt_ok": prompt_ok,
              "fix_attempts": fix_attempts,
              "live": False,
          }
      if not prompt_ok:
          return {
              "exercise": name,
              "difficulty": exercise["difficulty"],
              "title": exercise["title"],
              "mode": mode,
              "provider": provider,
              "workspace": str(workspace) if keep else None,
              "baseline_exit": baseline.returncode,
              "prompt_chars": len(prompt),
              "prompt_checks": checks,
              "prompt_ok": False,
              "fix_attempts": fix_attempts,
              "attempt_count": 0,
              "provider_exit": None,
              "applied": "not_run",
              "apply_error": "exercise prompt self-check failed",
              "test_exit": baseline.returncode,
              "scope_ok": True,
              "changed_files": [],
              "success": False,
              "final_text": "",
              "test_stdout": baseline.stdout[-2000:],
              "test_stderr": baseline.stderr[-2000:],
              "attempts": [],
          }

      attempts: list[dict[str, Any]] = []
      result: dict[str, Any] | None = None
      for attempt_no in range(fix_attempts + 1):
          proc, final_text = call_provider(provider, mode, prompt, workspace, timeout, with_mcp=with_mcp)
          applied = "direct"
          apply_error = None
          if mode == "nvime":
              try:
                  applied = apply_nvime_response(workspace, exercise, selection, final_text)
              except Exception as exc:  # noqa: BLE001 - surfaced in JSON result
                  applied = "apply_failed"
                  apply_error = str(exc)
          tests = run(runner, workspace, timeout=120)
          files = changed_files(workspace)
          scope_ok = files == [exercise["target"]]
          hidden_files: list[str] = []
          hidden_exit: int | None = None
          hidden_stdout = ""
          hidden_stderr = ""
          if proc.returncode == 0 and tests.returncode == 0 and scope_ok and applied not in {"unparsed", "no_change", "apply_failed"}:
              hidden_files = write_hidden_files(workspace, exercise)
              if hidden_files:
                  hidden = run(runner, workspace, timeout=120)
                  hidden_exit = hidden.returncode
                  hidden_stdout = hidden.stdout[-2000:]
                  hidden_stderr = hidden.stderr[-2000:]
          success = (
              proc.returncode == 0
              and tests.returncode == 0
              and (hidden_exit in {None, 0})
              and scope_ok
              and applied not in {"unparsed", "no_change", "apply_failed"}
          )
          attempt = {
              "attempt": attempt_no + 1,
              "provider_exit": proc.returncode,
              "applied": applied,
              "apply_error": apply_error,
              "test_exit": tests.returncode,
              "scope_ok": scope_ok,
              "changed_files": files,
              "success": success,
              "final_text": final_text[-2000:],
              "test_stdout": tests.stdout[-2000:],
              "test_stderr": tests.stderr[-2000:],
              "hidden_files": hidden_files,
              "hidden_exit": hidden_exit,
              "hidden_stdout": hidden_stdout,
              "hidden_stderr": hidden_stderr,
          }
          attempts.append(attempt)
          result = attempt
          if success or mode != "nvime" or attempt_no >= fix_attempts:
              break
          prompt = build_nvime_prompt(
              workspace,
              exercise,
              selection,
              feedback_intent(exercise["intent"], runner, attempt),
          )

      assert result is not None
      return {
          "exercise": name,
          "difficulty": exercise["difficulty"],
          "title": exercise["title"],
          "mode": mode,
          "provider": provider,
          "workspace": str(workspace) if keep else None,
          "baseline_exit": baseline.returncode,
          "prompt_checks": checks,
          "prompt_ok": prompt_ok,
          "fix_attempts": fix_attempts,
          "attempt_count": len(attempts),
          "provider_exit": result["provider_exit"],
          "applied": result["applied"],
          "apply_error": result["apply_error"],
          "test_exit": result["test_exit"],
          "scope_ok": result["scope_ok"],
          "changed_files": result["changed_files"],
          "success": result["success"],
          "final_text": result["final_text"],
          "test_stdout": result["test_stdout"],
          "test_stderr": result["test_stderr"],
          "hidden_files": result.get("hidden_files", []),
          "hidden_exit": result.get("hidden_exit"),
          "hidden_stdout": result.get("hidden_stdout", ""),
          "hidden_stderr": result.get("hidden_stderr", ""),
          "attempts": attempts,
      }
    finally:
      if not keep:
          shutil.rmtree(workspace, ignore_errors=True)


BASELINE_DIR = REPO_ROOT / "tests" / "fixtures" / "prompt-baselines"


def _scrub_prompt(text: str, workspace: Path) -> str:
    # Replace the nondeterministic tokens so the snapshot is stable across
    # machines/runs: the per-run temp workspace and the absolute repo root.
    for needle in (str(workspace), str(workspace.resolve()), os.path.realpath(str(workspace))):
        text = text.replace(needle, "<WORKSPACE>")
    for needle in (str(REPO_ROOT), os.path.realpath(str(REPO_ROOT))):
        text = text.replace(needle, "<REPO>")
    return text


def emit_prompts(out_dir: Path) -> int:
    """Build every mode/exercise prompt, scrub temp paths, and write it to
    out_dir/<mode>/<exercise>.txt. Returns the count written. No provider calls."""
    specs: list[tuple[str, str]] = []
    specs += [("nvime", name) for name in EXERCISES]
    specs += [("general", name) for name in GENERAL_EXERCISES]
    specs += [("plan", name) for name in PLAN_EXERCISES]
    count = 0
    for mode, name in specs:
        workspace = Path(tempfile.mkdtemp(prefix=f"nvime-emit-{mode}-{name}-"))
        try:
            if mode == "nvime":
                selection = prepare_exercise(name, workspace)
                prompt = build_nvime_prompt(workspace, EXERCISES[name], selection)
            elif mode == "general":
                prepare_general_exercise(name, workspace)
                prompt = build_general_prompt(workspace, GENERAL_EXERCISES[name]["intent"])
            else:
                prepare_plan_exercise(name, workspace)
                prompt = build_plan_prompt(workspace, PLAN_EXERCISES[name]["intent"])
            dest = out_dir / mode / f"{name}.txt"
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_text(_scrub_prompt(prompt, workspace), encoding="utf-8")
            count += 1
        finally:
            shutil.rmtree(workspace, ignore_errors=True)
    return count


def compare_runs(before_path: str, after_path: str) -> int:
    """Print a before/after benchmark comparison of two `--live` result JSON
    files: per-exercise pass/fail, aggregate pass rate, and any regressions
    (passed before, fails now). Returns 1 if there is at least one regression."""

    def load(path: str) -> dict[tuple[str, str], dict[str, Any]]:
        data = json.loads(Path(path).read_text(encoding="utf-8"))
        out = {}
        for r in data.get("results", []):
            out[(r.get("mode", "?"), r.get("exercise", "?"))] = r
        return out

    before = load(before_path)
    after = load(after_path)
    keys = sorted(set(before) | set(after))

    def mark(r: dict[str, Any] | None) -> str:
        if r is None:
            return "  -  "
        if r.get("skipped"):
            return "SKIP "
        return "PASS " if r.get("success") else "FAIL "

    regressions: list[str] = []
    improvements: list[str] = []
    print(f"{'mode/exercise':45} {'before':>7} {'after':>7}")
    print("-" * 61)
    for key in keys:
        b, a = before.get(key), after.get(key)
        label = f"{key[0]}/{key[1]}"
        print(f"{label:45} {mark(b):>7} {mark(a):>7}")
        # A skipped run (missing toolchain) is not a data point — never count it
        # as a regression or improvement.
        if (b and b.get("skipped")) or (a and a.get("skipped")):
            continue
        bs = bool(b and b.get("success"))
        as_ = bool(a and a.get("success"))
        if bs and not as_:
            regressions.append(label)
        elif as_ and not bs:
            improvements.append(label)

    def rate(m: dict[str, Any]) -> str:
        graded = [r for r in m.values() if not r.get("skipped")]
        total = len(graded)
        passed = sum(1 for r in graded if r.get("success"))
        return f"{passed}/{total}" if total else "0/0"

    print("-" * 61)
    print(f"pass rate: before {rate(before)} -> after {rate(after)}")
    if improvements:
        print(f"improved ({len(improvements)}): {', '.join(improvements)}")
    if regressions:
        print(f"REGRESSED ({len(regressions)}): {', '.join(regressions)}")
    return 1 if regressions else 0


def compare_prompt_trees(expected: Path, actual: Path) -> list[str]:
    exp = {p.relative_to(expected) for p in expected.rglob("*.txt")} if expected.exists() else set()
    act = {p.relative_to(actual) for p in actual.rglob("*.txt")}
    out = []
    for rel in sorted(exp - act):
        out.append(f"missing now (delete the stale baseline): {rel}")
    for rel in sorted(act - exp):
        out.append(f"new, uncommitted baseline: {rel}")
    for rel in sorted(exp & act):
        if (expected / rel).read_text(encoding="utf-8") != (actual / rel).read_text(encoding="utf-8"):
            out.append(f"changed: {rel}")
    return out


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--provider", choices=["codex", "claude"], default="codex")
    parser.add_argument("--mode", choices=["nvime", "default", "general", "plan", "plan-execute"], default="nvime")
    parser.add_argument(
        "--exercise",
        choices=["all", *EXERCISES.keys(), *GENERAL_EXERCISES.keys(), *PLAN_EXERCISES.keys()],
        default="all",
    )
    parser.add_argument("--live", action="store_true", help="actually call the provider CLI")
    parser.add_argument(
        "--with-mcp",
        action="store_true",
        help="attach nvime's MCP server (low-context nav tools) so you can A/B their effect (nvime/default mode, claude only)",
    )
    parser.add_argument("--keep", action="store_true", help="keep temporary workspaces")
    parser.add_argument("--timeout", type=int, default=600)
    parser.add_argument("--fix-attempts", type=int, default=0, help="nvime-mode test-feedback retries after a failed attempt")
    parser.add_argument("--list", action="store_true", help="list exercises and exit")
    parser.add_argument(
        "--emit-prompts",
        metavar="DIR",
        help="build every prompt, scrub temp paths, write to DIR/<mode>/<exercise>.txt, and exit (no provider calls)",
    )
    parser.add_argument(
        "--check-prompts",
        action="store_true",
        help="fail if the prompts the current code generates differ from the committed baselines",
    )
    parser.add_argument(
        "--update-baselines",
        action="store_true",
        help="regenerate the committed prompt baselines (leaves the tree dirty for you to commit)",
    )
    parser.add_argument(
        "--compare",
        nargs=2,
        metavar=("BEFORE", "AFTER"),
        help="compare two --live result JSON files: per-exercise pass/fail, pass rate, regressions",
    )
    args = parser.parse_args()

    if args.with_mcp and args.provider != "claude":
        parser.error("--with-mcp is currently wired for the claude provider only")
    if args.with_mcp and args.mode not in {"nvime", "default"}:
        parser.error("--with-mcp applies to nvime/default edit modes")

    if args.compare:
        return compare_runs(args.compare[0], args.compare[1])

    if args.emit_prompts:
        n = emit_prompts(Path(args.emit_prompts))
        print(f"emitted {n} prompts to {args.emit_prompts}")
        return 0

    if args.update_baselines:
        if BASELINE_DIR.exists():
            shutil.rmtree(BASELINE_DIR)
        n = emit_prompts(BASELINE_DIR)
        print(f"regenerated {n} prompt baselines at {BASELINE_DIR} — review and commit them")
        return 0

    if args.check_prompts:
        scratch = Path(tempfile.mkdtemp(prefix="nvime-prompt-check-"))
        try:
            emit_prompts(scratch)
            mismatches = compare_prompt_trees(BASELINE_DIR, scratch)
        finally:
            shutil.rmtree(scratch, ignore_errors=True)
        if mismatches:
            sys.stderr.write("prompt baselines differ from current code:\n  " + "\n  ".join(mismatches) + "\n")
            sys.stderr.write("run `scripts/agent-exercises --update-baselines`, review the diff, and commit it.\n")
            return 1
        print("prompt baselines match")
        return 0

    if args.list:
        for key, exercise in EXERCISES.items():
            print(f"edit\t{key}\t{exercise['difficulty']}\t{exercise['title']}")
        for key, exercise in GENERAL_EXERCISES.items():
            print(f"general\t{key}\t{exercise['difficulty']}\t{exercise['title']}")
        for key, exercise in PLAN_EXERCISES.items():
            print(f"plan\t{key}\t{exercise['difficulty']}\t{exercise['title']}")
            print(f"plan-execute\t{key}\t{exercise['difficulty']}\t{exercise['title']}")
        return 0

    if args.mode in {"nvime", "default"}:
        selected = list(EXERCISES) if args.exercise == "all" else [args.exercise]
        unknown = [name for name in selected if name not in EXERCISES]
        if unknown:
            parser.error(f"{args.mode} mode does not include exercises: {', '.join(unknown)}")
        results = [
            run_one(
                name,
                args.provider,
                args.mode,
                args.live,
                args.keep,
                args.timeout,
                max(args.fix_attempts, 0),
                with_mcp=args.with_mcp,
            )
            for name in selected
        ]
    elif args.mode == "general":
        selected = list(GENERAL_EXERCISES) if args.exercise == "all" else [args.exercise]
        unknown = [name for name in selected if name not in GENERAL_EXERCISES]
        if unknown:
            parser.error(f"general mode does not include exercises: {', '.join(unknown)}")
        results = [run_general_one(name, args.provider, args.live, args.keep, args.timeout) for name in selected]
    elif args.mode == "plan":
        selected = list(PLAN_EXERCISES) if args.exercise == "all" else [args.exercise]
        unknown = [name for name in selected if name not in PLAN_EXERCISES]
        if unknown:
            parser.error(f"plan mode does not include exercises: {', '.join(unknown)}")
        results = [run_plan_one(name, args.provider, args.live, args.keep, args.timeout) for name in selected]
    else:
        selected = list(PLAN_EXERCISES) if args.exercise == "all" else [args.exercise]
        unknown = [name for name in selected if name not in PLAN_EXERCISES]
        if unknown:
            parser.error(f"plan-execute mode does not include exercises: {', '.join(unknown)}")
        results = [
            run_plan_execute_one(name, args.provider, args.live, args.keep, args.timeout, max(args.fix_attempts, 0))
            for name in selected
        ]
    print(json.dumps({"results": results}, indent=2, sort_keys=True))
    graded = [item for item in results if not item.get("skipped")]
    if any(not item.get("prompt_ok", True) for item in graded):
        return 1
    if args.live and any(not item.get("success") for item in graded):
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
