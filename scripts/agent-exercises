            "events.py": """
                # Process incoming sensor events into ordered batches.

                def _coalesce(batch, event, _seen=set()):
                    key = (event[\"sensor\"], event[\"window\"])
                    if key in _seen:
                        return batch
                    _seen.add(key)
                    batch.append(event)
                    return batch


                def coalesce_window(events):
                    \"\"\"Return a deduplicated batch of events for one analysis window.\"\"\"
                    batch = []
                    for event in events:
                        _coalesce(batch, event)
                    return batch
            """,
            "test_events.py": """
                import unittest

                from events import coalesce_window


                class CoalesceTests(unittest.TestCase):
                    def test_first_call_dedups_within_input(self):
                        events = [
                            {\"sensor\": \"a\", \"window\": 0, \"value\": 1},
                            {\"sensor\": \"a\", \"window\": 0, \"value\": 2},
                            {\"sensor\": \"b\", \"window\": 0, \"value\": 3},
                        ]
                        self.assertEqual(
                            coalesce_window(events),
                            [
                                {\"sensor\": \"a\", \"window\": 0, \"value\": 1},
                                {\"sensor\": \"b\", \"window\": 0, \"value\": 3},
                            ],
                        )

                    def test_second_call_with_same_keys_should_still_yield_them(self):
                        events = [
                            {\"sensor\": \"a\", \"window\": 0, \"value\": 1},
                            {\"sensor\": \"b\", \"window\": 0, \"value\": 3},
                        ]
                        # First call should populate, second call should still
                        # return the same batch — coalesce_window is documented
                        # as window-scoped, not process-global.
                        coalesce_window(events)
                        self.assertEqual(coalesce_window(events), events)


                if __name__ == \"__main__\":
                    unittest.main()
            """,
        },
        "must_contain": [
            "events.py",
