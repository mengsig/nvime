    "cross_file_progressive_tax": {
        "difficulty": "hard",
        "title": "Compute progressive marginal tax across sibling tables",
        "target": "payroll.py",
        "intent": (
            "Fix net_pay so it computes income tax for `country` using the MARGINAL "
            "brackets in brackets.py (each rate applies only to the income within that "
            "band, not to the whole gross), subtracts the tax from gross, and rounds the "
            "result with money.round_money. Raise ValueError for an unknown country. A "
            "gross of 0 or less costs 0.0. Read brackets.py and money.py — do not "
            "hardcode the rates, bands, or rounding rule."
