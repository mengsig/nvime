        "difficulty": "easy",
        "title": "Implement normalized slug generation",
        "target": "text_utils.py",
        "intent": (
            "Implement slugify so it lowercases text, removes punctuation, "
            "collapses whitespace/punctuation runs to one hyphen, and trims "
            "leading/trailing hyphens."
        ),
        "files": {
            "text_utils.py": """
                import re


                def slugify(value):
                    # NVIME_SELECT_START
                    return value.lower().replace(" ", "-")
                    # NVIME_SELECT_END
            """,
            "test_text_utils.py": """
                import unittest

                from text_utils import slugify


                class SlugifyTests(unittest.TestCase):
                    def test_normalizes_words_and_punctuation(self):
                        self.assertEqual(slugify("Hello, World!"), "hello-world")

                    def test_collapses_runs(self):
                        self.assertEqual(slugify("  A---B__C  "), "a-b-c")

                    def test_empty_after_cleanup(self):
                        self.assertEqual(slugify("!!!"), "")


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
    },
    "medium_duration_parser": {
        "difficulty": "medium",
        "title": "Fix compact duration parsing",
        "target": "durations.py",
        "intent": (
            "Fix parse_duration to accept compact multi-unit strings such as "
            "1h30m and spaced strings such as 2h 5m. Invalid or empty inputs "
            "must raise ValueError."
        ),
        "files": {
            "durations.py": """
                _UNIT_SECONDS = {
                    "s": 1,
                    "m": 60,
                    "h": 60 * 60,
                    "d": 24 * 60 * 60,
                }


                def parse_duration(expr):
                    # NVIME_SELECT_START
                    total = 0
                    for part in expr.split():
                        amount = int(part[:-1])
                        unit = part[-1]
                        total += amount * _UNIT_SECONDS[unit]
                    return total
                    # NVIME_SELECT_END
            """,
            "test_durations.py": """
                import unittest

                from durations import parse_duration


                class DurationParserTests(unittest.TestCase):
                    def test_compact_units(self):
                        self.assertEqual(parse_duration("1h30m5s"), 5405)

                    def test_spaced_units(self):
                        self.assertEqual(parse_duration("2h 5m"), 7500)

                    def test_days(self):
                        self.assertEqual(parse_duration("1d2h"), 93600)

                    def test_invalid_inputs(self):
                        for value in ["", "   ", "10", "m10", "3w", "1h-2m"]:
                            with self.subTest(value=value):
                                with self.assertRaises(ValueError):
                                    parse_duration(value)


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
    },
    "hard_half_open_windows": {
        "difficulty": "hard",
        "title": "Preserve half-open interval semantics",
        "target": "windows.py",
        "intent": (
            "Fix merge_windows for half-open [start, end) intervals: overlap "
            "should merge, adjacency should not merge, empty windows should be "
            "ignored, and reversed windows should raise ValueError."
        ),
        "files": {
            "windows.py": """
                def merge_windows(windows):
                    # NVIME_SELECT_START
                    ordered = sorted(windows)
                    merged = []
                    for start, end in ordered:
                        if not merged or start > merged[-1][1]:
                            merged.append([start, end])
                        else:
                            merged[-1][1] = max(merged[-1][1], end)
                    return [tuple(item) for item in merged]
                    # NVIME_SELECT_END
            """,
            "test_windows.py": """
                import unittest

                from windows import merge_windows


                class MergeWindowsTests(unittest.TestCase):
                    def test_merges_only_overlap(self):
                        self.assertEqual(
                            merge_windows([(5, 8), (1, 4), (3, 6), (8, 10)]),
                            [(1, 8), (8, 10)],
                        )

                    def test_adjacency_is_not_overlap(self):
                        self.assertEqual(merge_windows([(1, 2), (2, 3)]), [(1, 2), (2, 3)])

                    def test_ignores_empty_windows(self):
                        self.assertEqual(merge_windows([(1, 1), (1, 2), (3, 3)]), [(1, 2)])

                    def test_rejects_reversed_window(self):
                        with self.assertRaises(ValueError):
                            merge_windows([(4, 2)])


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
    },
    "extremely_difficult_safe_join": {
        "difficulty": "extremely_difficult",
        "title": "Close symlink path escape in a repo path helper",
        "target": "safe_paths.py",
        "intent": (
            "Harden safe_join so callers cannot escape the base directory via "
            "absolute paths, parent traversal, or a symlink inside the base. "
            "Return the joined path for valid in-base files."
        ),
        "files": {
            "safe_paths.py": """
                import os


                def safe_join(base, rel):
                    # NVIME_SELECT_START
                    if not rel:
                        raise ValueError("empty path")
                    if rel.startswith(os.sep):
                        raise ValueError("absolute path")
                    for segment in rel.split("/"):
                        if segment == "..":
                            raise ValueError("parent traversal")
                    return os.path.join(base, rel)
                    # NVIME_SELECT_END
            """,
            "test_safe_paths.py": """
                import os
                import tempfile
                import unittest

                from safe_paths import safe_join


                class SafeJoinTests(unittest.TestCase):
                    def test_allows_normal_child_path(self):
                        with tempfile.TemporaryDirectory() as base:
                            os.mkdir(os.path.join(base, "src"))
                            target = os.path.join(base, "src", "main.py")
                            open(target, "w").close()
                            self.assertEqual(safe_join(base, "src/main.py"), target)

                    def test_blocks_absolute_and_parent_paths(self):
                        with tempfile.TemporaryDirectory() as base:
                            with self.assertRaises(ValueError):
                                safe_join(base, "/etc/passwd")
                            with self.assertRaises(ValueError):
                                safe_join(base, "../secret")

                    def test_blocks_symlink_escape(self):
                        with tempfile.TemporaryDirectory() as base, tempfile.TemporaryDirectory() as outside:
                            secret = os.path.join(outside, "secret.txt")
                            open(secret, "w").close()
                            os.symlink(outside, os.path.join(base, "link"))
                            with self.assertRaises(ValueError):
                                safe_join(base, "link/secret.txt")


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
    },
    "extremely_difficult_json_patch": {
        "difficulty": "extremely_difficult",
        "title": "Implement JSON Pointer based patch operations",
        "target": "json_patch.py",
        "intent": (
            "Implement apply_patch for an RFC 6902 style subset: add, remove, "
            "and replace using JSON Pointer paths. It must handle object keys "
            "with ~0/~1 escaping, list indexes including '-' for append on add, "
            "reject invalid paths/operations with ValueError, and never mutate "
            "the input document when validation fails."
        ),
        "files": {
            "json_patch.py": """
                import copy


                def _split_pointer(pointer):
                    if pointer == "":
                        return []
                    if not isinstance(pointer, str) or not pointer.startswith("/"):
                        raise ValueError("invalid JSON pointer")
                    parts = pointer[1:].split("/")
                    return [part.replace("~1", "/").replace("~0", "~") for part in parts]


                def apply_patch(document, operations):
                    # NVIME_SELECT_START
                    result = document
                    for operation in operations:
                        if operation["op"] == "replace":
                            result[operation["path"]] = operation["value"]
                    return result
                    # NVIME_SELECT_END
            """,
            "test_json_patch.py": """
                import unittest

                from json_patch import apply_patch


                class JsonPatchTests(unittest.TestCase):
                    def test_replace_add_remove_with_escaped_pointer(self):
                        original = {"a/b": {"items": [1, 2, 3]}, "keep": True}
                        result = apply_patch(original, [
                            {"op": "replace", "path": "/a~1b/items/1", "value": 20},
                            {"op": "add", "path": "/a~1b/items/-", "value": 4},
                            {"op": "remove", "path": "/keep"},
                        ])
                        self.assertEqual(result, {"a/b": {"items": [1, 20, 3, 4]}})
                        self.assertEqual(original, {"a/b": {"items": [1, 2, 3]}, "keep": True})

                    def test_add_object_field(self):
                        self.assertEqual(
                            apply_patch({"meta": {}}, [{"op": "add", "path": "/meta/name", "value": "nvime"}]),
                            {"meta": {"name": "nvime"}},
                        )

                    def test_invalid_operation_is_atomic(self):
                        original = {"items": [1, 2, 3]}
                        with self.assertRaises(ValueError):
                            apply_patch(original, [
                                {"op": "replace", "path": "/items/0", "value": 99},
                                {"op": "remove", "path": "/items/99"},
                            ])
                        self.assertEqual(original, {"items": [1, 2, 3]})

                    def test_rejects_unknown_op_and_bad_list_index(self):
                        with self.assertRaises(ValueError):
                            apply_patch({}, [{"op": "move", "path": "/a", "value": 1}])
                        with self.assertRaises(ValueError):
                            apply_patch({"items": []}, [{"op": "add", "path": "/items/2", "value": 1}])


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
    },
    "extremely_difficult_topological_batches": {
        "difficulty": "extremely_difficult",
        "title": "Implement stable dependency batches",
        "target": "scheduler.py",
        "intent": (
            "Implement build_batches for task dictionaries with id and deps. "
            "Return deterministic execution batches in input order within each "
            "batch, reject duplicate ids, missing dependencies, and cycles with "
            "ValueError, and do not mutate the input task dictionaries."
        ),
        "files": {
            "scheduler.py": """
                def build_batches(tasks):
                    # NVIME_SELECT_START
                    return [[task["id"] for task in tasks]]
                    # NVIME_SELECT_END
            """,
            "test_scheduler.py": """
                import copy
                import unittest

                from scheduler import build_batches


                class BuildBatchesTests(unittest.TestCase):
                    def test_stable_batches(self):
                        tasks = [
                            {"id": "fetch", "deps": []},
                            {"id": "parse", "deps": ["fetch"]},
                            {"id": "validate", "deps": ["fetch"]},
                            {"id": "store", "deps": ["parse", "validate"]},
                        ]
                        self.assertEqual(build_batches(tasks), [["fetch"], ["parse", "validate"], ["store"]])

                    def test_accepts_missing_deps_key_as_empty(self):
                        self.assertEqual(build_batches([{"id": "solo"}]), [["solo"]])

                    def test_rejects_duplicate_and_missing_deps(self):
                        with self.assertRaises(ValueError):
                            build_batches([{"id": "a"}, {"id": "a"}])
                        with self.assertRaises(ValueError):
                            build_batches([{"id": "a", "deps": ["missing"]}])

                    def test_rejects_cycles(self):
                        with self.assertRaises(ValueError):
                            build_batches([
                                {"id": "a", "deps": ["c"]},
                                {"id": "b", "deps": ["a"]},
                                {"id": "c", "deps": ["b"]},
                            ])

                    def test_does_not_mutate_input(self):
                        tasks = [{"id": "b", "deps": ["a"]}, {"id": "a", "deps": []}]
                        before = copy.deepcopy(tasks)
                        build_batches(tasks)
                        self.assertEqual(tasks, before)


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
    },
}


