                def next_state(current, event):
                    # NVIME_SELECT_START
                    return event
                    # NVIME_SELECT_END
            """,
            "transitions.py": """
                # Allowed (from_state, event) -> to_state. Anything not listed is invalid.
                TRANSITIONS = {
                    ("draft", "submit"): "review",
                    ("review", "approve"): "published",
                    ("review", "reject"): "draft",
                    ("published", "archive"): "archived",
                }

