    "cross_file_pricing_rules": {
        "difficulty": "hard",
        "title": "Apply pricing rules defined in sibling files",
        "target": "pricing.py",
        "intent": (
            "Fix total_price so it computes the cart subtotal, applies the correct discount "
            "tier from rules.py (the highest tier threshold the subtotal reaches, inclusive), "
            "then applies tax, then rounds the final amount with money.round_money. An empty "
            "cart costs 0.0. Read rules.py and money.py for the exact tiers, tax rate, and "
            "rounding rule — do not hardcode those values."
        ),
        "files": {
            "pricing.py": """
                from rules import DISCOUNT_TIERS, TAX_RATE
                from money import round_money


                def total_price(cart):
                    # NVIME_SELECT_START
                    return sum(item["price"] * item["qty"] for item in cart)
                    # NVIME_SELECT_END
            """,
            "rules.py": """
                # Discount tiers as (subtotal_threshold, rate_off). The HIGHEST threshold
                # the pre-tax subtotal reaches (inclusive) wins. Tax is applied AFTER the
                # discount.
                DISCOUNT_TIERS = [(0, 0.0), (100, 0.05), (500, 0.10), (1000, 0.15)]
                TAX_RATE = 0.08
            """,
            "money.py": """
                from decimal import Decimal, ROUND_HALF_UP


                def round_money(amount):
                    # Round to 2 decimal places, half-up, returning a float.
                    return float(Decimal(str(amount)).quantize(Decimal("0.01"), rounding=ROUND_HALF_UP))
            """,
            "test_pricing.py": """
                import unittest

                from pricing import total_price


                class PricingTests(unittest.TestCase):
                    def test_no_discount_small_cart(self):
                        self.assertEqual(total_price([{"price": 20.0, "qty": 2}]), 43.2)

                    def test_mid_tier_discount(self):
                        self.assertEqual(total_price([{"price": 100.0, "qty": 2}]), 205.2)

                    def test_empty_cart(self):
                        self.assertEqual(total_price([]), 0.0)


                if __name__ == "__main__":
                    unittest.main()
            """,
        },
