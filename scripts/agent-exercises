                        tasks = [
                            {"id": "deploy", "deps": ["package", "migrate"]},
                            {"id": "fetch", "deps": []},
                            {"id": "package", "deps": ["build"]},
                            {"id": "migrate", "deps": ["fetch"]},
                            {"id": "build", "deps": ["fetch"]},
                        ]
                        self.assertEqual(build_batches(tasks), [["fetch"], ["migrate", "build"], ["package"], ["deploy"]])

                    def test_empty_input_is_empty_batches(self):
                        self.assertEqual(build_batches([]), [])

                    def test_duplicate_is_checked_before_missing_dependency(self):
