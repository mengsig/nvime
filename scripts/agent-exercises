    "extremely_difficult_csv_parser": {
        "difficulty": "extremely_difficult",
        "title": "Implement strict RFC 4180 CSV row parser",
        "target": "csv_parser.py",
        "intent": (
            "Implement parse_csv(text) returning a list of rows; each row is a "
            "list of string fields. Follow RFC 4180 strictly: comma separator, "
            "double-quote escaping for embedded quotes inside quoted fields, "
            "quoted fields may contain commas and newlines (LF or CRLF), "
            "unquoted fields may not contain quotes or separators, the input is "
            "treated as the body of a file (a trailing single newline does not "
            "produce an extra empty row, but a doubled trailing newline does), "
            "empty fields stay empty (so 'a,,b' is three fields), and "
            "malformed input (unterminated quoted field, bare quote inside an "
            "unquoted field, stray quote after a quoted field's closing quote) "
            "must raise ValueError."
        ),
        "files": {
            "csv_parser.py": """
                def parse_csv(text):
                    # NVIME_SELECT_START
                    rows = []
                    for line in text.split(\"\\n\"):
                        rows.append(line.split(\",\"))
                    return rows
                    # NVIME_SELECT_END
            """,
            "test_csv_parser.py": """
                import unittest

                from csv_parser import parse_csv


                class CsvParserTests(unittest.TestCase):
                    def test_simple_row(self):
                        self.assertEqual(parse_csv(\"a,b,c\"), [[\"a\", \"b\", \"c\"]])

                    def test_empty_fields_preserved(self):
                        self.assertEqual(parse_csv(\"a,,b\"), [[\"a\", \"\", \"b\"]])

                    def test_quoted_field_with_comma_and_newline(self):
                        text = 'name,note\\n\"Doe, J.\",\"line1\\nline2\"\\n'
                        self.assertEqual(
                            parse_csv(text),
                            [[\"name\", \"note\"], [\"Doe, J.\", \"line1\\nline2\"]],
                        )

                    def test_escaped_double_quote(self):
                        self.assertEqual(parse_csv('\"he said \"\"hi\"\"\"'), [['he said \"hi\"']])

                    def test_crlf_line_endings(self):
                        self.assertEqual(parse_csv(\"a,b\\r\\nc,d\\r\\n\"), [[\"a\", \"b\"], [\"c\", \"d\"]])

                    def test_trailing_newline_is_not_extra_row(self):
                        self.assertEqual(parse_csv(\"a,b\\n\"), [[\"a\", \"b\"]])

                    def test_doubled_trailing_newline_is_blank_row(self):
                        self.assertEqual(parse_csv(\"a,b\\n\\n\"), [[\"a\", \"b\"], [\"\"]])

                    def test_rejects_unterminated_quote(self):
                        with self.assertRaises(ValueError):
                            parse_csv('\"abc')

                    def test_rejects_bare_quote_in_unquoted_field(self):
                        with self.assertRaises(ValueError):
                            parse_csv('ab\"c')

                    def test_rejects_stray_text_after_closing_quote(self):
                        with self.assertRaises(ValueError):
                            parse_csv('\"abc\"def')


                if __name__ == \"__main__\":
                    unittest.main()
            """,
        },
        "hidden_files": {
            "test_hidden_csv_parser.py": """
                import unittest

                from csv_parser import parse_csv


                class HiddenCsvParserTests(unittest.TestCase):
                    def test_empty_input_is_empty_list(self):
                        self.assertEqual(parse_csv(\"\"), [])

                    def test_only_newline_is_one_blank_row(self):
                        self.assertEqual(parse_csv(\"\\n\"), [[\"\"]])

                    def test_quoted_empty_field(self):
                        self.assertEqual(parse_csv('a,\"\",b'), [[\"a\", \"\", \"b\"]])

                    def test_three_consecutive_double_quotes_is_one_quote(self):
                        self.assertEqual(parse_csv('\"\"\"\"'), [['\"']])

                    def test_quoted_field_with_crlf_inside(self):
                        self.assertEqual(parse_csv('\"a\\r\\nb\",c'), [[\"a\\r\\nb\", \"c\"]])

                    def test_trailing_separator_creates_empty_field(self):
                        self.assertEqual(parse_csv(\"a,b,\"), [[\"a\", \"b\", \"\"]])


                if __name__ == \"__main__\":
                    unittest.main()
            """,
        },
