#!/usr/bin/env python3
"""Run graded nvime prompt exercises against Claude or Codex CLI.

The script builds throwaway Python projects, generates the real nvime edit
prompt through Neovim, optionally asks a provider to solve the task, applies
NVIME_DIFF/NVIME_REPLACEMENT output, and runs the exercise tests.

Live provider calls are opt-in with --live because they can spend tokens.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import textwrap
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
RUNNER = "python -m unittest -q"


def runner_for(exercise: dict[str, Any]) -> str:
    """Per-exercise test runner, defaulting to the Python harness.

    Lets a fixture be written in ANY language: it just declares its own
    `runner` shell command (e.g. "sh test.sh", "node --test"). Grading only
    cares about the runner's exit code, never its language — so the framework
    stays completely language-agnostic.
    """
    return exercise.get("runner") or RUNNER


def runner_available(runner: str) -> bool:
    """True if the runner's executable is on PATH.

    A multi-language fixture may need a toolchain the current machine lacks; a
    missing runner yields a clean `skipped` result instead of a spurious
    failure that would pollute the pass-rate comparison.
    """
    parts = runner.split()
    return bool(parts) and shutil.which(parts[0]) is not None


